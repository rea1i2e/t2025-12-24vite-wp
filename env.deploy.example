# `.env.deploy` の雛形（`cp env.deploy.example .env.deploy` でコピーし、値のみ入れる）。
# `.env.deploy` は .gitignore 済み。credentials は Git に載せない。
# 自動生成: `.env.deploy` を手元ツール／ナレッジの `generate-env-deploy.sh '<案件ID>' <リポルート> --wordpress` で出す運用がある。

FTP_SERVER=ftp.example.com
FTP_USERNAME=your-case-id@rea1i2e.net
FTP_PASSWORD=your-password

# Actions のテーマ転送先。案件リポは GitHub のリポ名と揃える: /wp-content/themes/<リポ名>/
FTP_SERVER_DIR=/wp-content/themes/YOUR_REPO_SLUG/
# staging/docroot（サイト全体 Basic 等）の転送先。サブFTPのチルートが docroot なら多くは /
FTP_SERVER_DIR_DOCROOT=/

# Actions サマリー／Discord 用。自動生成では docroot Basic と同一規則の user:pass を埋め込むことが多い: https://USER:PASS@YOUR_REPO_SLUG.rea1i2e.net/
TEST_URL=https://USER:PASS@YOUR_REPO_SLUG.rea1i2e.net/
DISCORD_WEBHOOK=
